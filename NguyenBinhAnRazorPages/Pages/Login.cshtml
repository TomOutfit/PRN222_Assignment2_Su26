@page
@model NguyenBinhAnRazorPages.Pages.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_LayoutLogin";
}
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<style>
    :root {
        --cyan: #00ffff;
        --mag: #ff00ff;
        --dark: #050510;
    }

    body {
        font-family: 'Rajdhani', sans-serif;
        margin: 0;
        background: var(--dark);
        min-height: 100vh;
        overflow: hidden;
    }

    .login-root {
        display: flex;
        min-height: 100vh;
    }

    /* ===== LEFT - FORM PANEL ===== */
    .login-form-panel {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(5, 5, 16, 0.95);
        position: relative;
        z-index: 1;
        padding: 40px;
    }

    .login-form-panel::before {
        content: '';
        position: absolute;
        top: -200px; left: -100px;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(0,255,255,0.07), transparent);
        border-radius: 50%;
        pointer-events: none;
    }

    .login-form-panel::after {
        content: '';
        position: absolute;
        bottom: -100px; right: -50px;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(255,0,255,0.07), transparent);
        border-radius: 50%;
        pointer-events: none;
    }

    .login-box {
        width: 100%;
        max-width: 440px;
    }

    .login-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 40px;
        text-decoration: none;
    }

    .login-brand-icon {
        width: 44px; height: 44px;
        background: linear-gradient(135deg, var(--cyan), var(--mag));
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: var(--dark);
        font-size: 20px;
        box-shadow: 0 0 20px rgba(0,255,255,0.3);
    }

    .login-brand-text {
        font-family: 'Orbitron', sans-serif;
        font-weight: 800;
        font-size: 22px;
        color: #fff;
        letter-spacing: 2px;
    }

    .login-brand-text span { color: var(--cyan); }

    .login-heading {
        font-family: 'Orbitron', sans-serif;
        font-size: 28px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 6px;
        letter-spacing: 1px;
    }

    .login-sub {
        font-size: 15px;
        color: rgba(255,255,255,0.45);
        margin-bottom: 36px;
        font-weight: 400;
    }

    .form-field {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
        margin-bottom: 8px;
    }

    .cyber-input {
        width: 100%;
        padding: 14px 16px 14px 48px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 8px;
        color: #fff;
        font-size: 15px;
        font-family: 'Rajdhani', sans-serif;
        transition: all 0.3s;
        box-sizing: border-box;
    }

    .cyber-input:focus {
        outline: none;
        border-color: var(--cyan);
        background: rgba(0,255,255,0.04);
        box-shadow: 0 0 0 3px rgba(0,255,255,0.1), 0 0 20px rgba(0,255,255,0.1);
    }

    .cyber-input::placeholder { color: rgba(255,255,255,0.2); }

    .input-wrap {
        position: relative;
    }

    .input-wrap .input-icon {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(0,255,255,0.5);
        font-size: 16px;
        transition: color 0.3s;
    }

    .cyber-input:focus ~ .input-icon { color: var(--cyan); }

    .form-options {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .cyber-check {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .cyber-check input {
        width: 16px; height: 16px;
        accent-color: var(--cyan);
        cursor: pointer;
    }

    .cyber-check label {
        font-size: 14px;
        color: rgba(255,255,255,0.5);
        cursor: pointer;
    }

    .forgot-link {
        font-size: 13px;
        color: var(--mag);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;
    }

    .forgot-link:hover { color: #ff66ff; }

    .btn-signin-cyber {
        width: 100%;
        padding: 15px;
        background: linear-gradient(135deg, var(--cyan), #00aaff);
        border: none;
        border-radius: 8px;
        color: var(--dark);
        font-family: 'Orbitron', sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 0 20px rgba(0,255,255,0.2);
        clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));
    }

    .btn-signin-cyber:hover {
        box-shadow: 0 0 40px rgba(0,255,255,0.5);
        transform: translateY(-2px);
    }

    .guest-link {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
        color: rgba(255,255,255,0.35);
    }

    .guest-link a {
        color: var(--cyan);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.3s;
    }

    .guest-link a:hover { color: #fff; }

    .validation-summary {
        background: rgba(255,0,50,0.08);
        border: 1px solid rgba(255,0,50,0.25);
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 20px;
    }

    .validation-summary ul { margin: 0; padding-left: 20px; }
    .validation-summary li { color: #ff6666; font-size: 14px; }

    .text-danger { color: #ff6666; font-size: 13px; margin-top: 6px; display: block; }

    /* ===== RIGHT - VISUAL PANEL ===== */
    .login-visual-panel {
        flex: 1.2;
        background: var(--dark);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .visual-grid {
        position: absolute;
        inset: 0;
        background:
            linear-gradient(transparent 49.5%, rgba(0,255,255,0.04) 50%, transparent 50.5%),
            linear-gradient(90deg, transparent 49.5%, rgba(0,255,255,0.04) 50%, transparent 50.5%);
        background-size: 50px 50px;
    }

    .visual-glow {
        position: absolute;
        width: 600px; height: 600px;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.2;
        animation: visualPulse 8s ease-in-out infinite;
    }

    .visual-glow-1 {
        background: var(--cyan);
        top: -200px; right: -200px;
    }

    .visual-glow-2 {
        background: var(--mag);
        bottom: -200px; left: -200px;
        animation-delay: -4s;
    }

    @@keyframes visualPulse {
        0%, 100% { opacity: 0.15; transform: scale(1); }
        50%       { opacity: 0.25; transform: scale(1.1); }
    }

    .visual-content {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .visual-icon {
        width: 140px; height: 140px;
        margin: 0 auto 32px;
        background: linear-gradient(135deg, rgba(0,255,255,0.1), rgba(255,0,255,0.1));
        border: 1px solid rgba(0,255,255,0.2);
        border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        font-size: 60px;
        animation: iconFloat 6s ease-in-out infinite;
    }

    @@keyframes iconFloat {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50%       { transform: translateY(-16px) rotate(3deg); }
    }

    .visual-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 56px;
        font-weight: 900;
        letter-spacing: 6px;
        color: #fff;
        margin-bottom: 16px;
    }

    .visual-title span {
        background: linear-gradient(90deg, var(--cyan), var(--mag));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .visual-tagline {
        font-size: 16px;
        color: rgba(255,255,255,0.5);
        letter-spacing: 3px;
        text-transform: uppercase;
    }

    .visual-features {
        display: flex;
        gap: 32px;
        justify-content: center;
        margin-top: 40px;
        flex-wrap: wrap;
    }

    .visual-feature {
        display: flex;
        align-items: center;
        gap: 8px;
        color: rgba(255,255,255,0.4);
        font-size: 13px;
        font-weight: 500;
    }

    .visual-feature i { color: var(--cyan); }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 992px) {
        .login-visual-panel { display: none; }
        .login-form-panel { flex: 1; }
    }
</style>

<div class="login-root">
    <!-- Form Panel -->
    <div class="login-form-panel">
        <div class="login-box">
            <a class="login-brand" asp-area="" asp-page="/Index">
                <div class="login-brand-icon"><i class="bi bi-newspaper"></i></div>
                <span class="login-brand-text">FUN<span>NEWS</span></span>
            </a>

            <h1 class="login-heading">Welcome Back</h1>
            <p class="login-sub">Sign in to access your account</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-field">
                    <label class="form-label">Email Address</label>
                    <div class="input-wrap">
                        <input asp-for="Email" class="cyber-input" placeholder="Enter your email" />
                        <span class="input-icon"><i class="bi bi-envelope"></i></span>
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-field">
                    <label class="form-label">Password</label>
                    <div class="input-wrap">
                        <input asp-for="Password" type="password" class="cyber-input" placeholder="Enter your password" />
                        <span class="input-icon"><i class="bi bi-lock"></i></span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-options">
                    <div class="cyber-check">
                        <input type="checkbox" id="rememberMe" name="rememberMe" />
                        <label for="rememberMe">Remember me</label>
                    </div>
                    <a href="#" class="forgot-link">Forgot Password?</a>
                </div>

                <button type="submit" class="btn-signin-cyber">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="validation-summary mt-3">
                        <ul><li>@Model.ErrorMessage</li></ul>
                    </div>
                }
            </form>

            <div class="guest-link">
                <a href="/News/View">
                    <i class="bi bi-compass me-1"></i>Continue as Guest — Browse News
                </a>
            </div>
        </div>
    </div>

    <!-- Visual Panel -->
    <div class="login-visual-panel">
        <div class="visual-grid"></div>
        <div class="visual-glow visual-glow-1"></div>
        <div class="visual-glow visual-glow-2"></div>

        <div class="visual-content">
            <div class="visual-icon">
                <i class="bi bi-newspaper" style="background: linear-gradient(135deg, var(--cyan), var(--mag)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
            </div>
            <h1 class="visual-title">FUN<span>NEWS</span></h1>
            <p class="visual-tagline">Your portal to breaking stories</p>

            <div class="visual-features">
                <div class="visual-feature">
                    <i class="bi bi-lightning-charge-fill"></i> Real-time News
                </div>
                <div class="visual-feature">
                    <i class="bi bi-shield-check"></i> Secure Access
                </div>
                <div class="visual-feature">
                    <i class="bi bi-bar-chart-fill"></i> Analytics
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@page
@model NguyenBinhAnRazorPages.Pages.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<style>
    body { font-family: 'Rajdhani', sans-serif; background: var(--bg-main); color: var(--text-main); }
</style>

<div class="container-fluid py-4" style="position:relative; z-index:1;">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-family:'Orbitron',sans-serif; font-size:1.6rem; color:var(--text-main); margin-bottom:4px;">
                <i class="bi bi-person-fill me-2" style="color:#0077b6;"></i> My Profile
            </h2>
            <p style="color:var(--text-muted); font-size:14px; margin:0;">Manage your account information</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Profile Form -->
        <div class="col-lg-8">
            <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; overflow:hidden;">
                <div style="background:rgba(0,119,182,0.03); border-bottom:1px solid rgba(0,119,182,0.08); padding:16px 24px;">
                    <h5 style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:14px; margin:0; letter-spacing:1px;">
                        <i class="bi bi-id-card me-2" style="color:#0077b6;"></i>Profile Information
                    </h5>
                </div>
                <div style="padding:24px;">
                    <form id="profileForm" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; display:block; margin-bottom:8px;">Full Name</label>
                                <input type="text" class="form-control" id="accountName" name="AccountName"
                                       value="@Model.Account?.AccountName" required
                                       style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:12px 14px; font-size:15px;" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; display:block; margin-bottom:8px;">Email Address</label>
                                <input type="email" class="form-control" id="accountEmail" name="AccountEmail"
                                       value="@Model.Account?.AccountEmail" readonly
                                       style="background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:12px 14px; font-size:15px;" />
                                <small style="color:var(--text-muted); opacity:0.6; font-size:11px; margin-top:4px; display:block;">Email cannot be changed.</small>
                            </div>
                            <div class="col-12">
                                <hr style="border-color:rgba(0,0,0,0.05);" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; display:block; margin-bottom:8px;">Current Password</label>
                                <input type="password" class="form-control" id="currentPassword" name="CurrentPassword"
                                       style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:12px 14px; font-size:15px;" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; display:block; margin-bottom:8px;">New Password</label>
                                <input type="password" class="form-control" id="newPassword" name="NewPassword"
                                       style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:12px 14px; font-size:15px;" />
                                <small style="color:var(--text-muted); opacity:0.6; font-size:11px; margin-top:4px; display:block;">Leave blank to keep current.</small>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; display:block; margin-bottom:8px;">Confirm Password</label>
                                <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword"
                                       style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:12px 14px; font-size:15px;" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; display:block; margin-bottom:8px;">Role</label>
                                <div>
                                    @switch (Model.Account?.AccountRole)
                                    {
                                        case 0:
                                            <span style="background:rgba(220,38,38,0.08); color:#dc2626; border:1px solid rgba(220,38,38,0.2); padding:6px 16px; border-radius:50px; font-size:13px; font-weight:700; display:inline-flex; align-items:center; gap:6px;">
                                                <i class="bi bi-shield-check"></i> Administrator
                                            </span>
                                            break;
                                        case 1:
                                            <span style="background:rgba(0,119,182,0.08); color:#0077b6; border:1px solid rgba(0,119,182,0.2); padding:6px 16px; border-radius:50px; font-size:13px; font-weight:700; display:inline-flex; align-items:center; gap:6px;">
                                                <i class="bi bi-person-badge"></i> Staff Member
                                            </span>
                                            break;
                                        case 2:
                                            <span style="background:rgba(217,119,6,0.08); color:#d97706; border:1px solid rgba(217,119,6,0.2); padding:6px 16px; border-radius:50px; font-size:13px; font-weight:700; display:inline-flex; align-items:center; gap:6px;">
                                                <i class="bi bi-mortarboard"></i> Lecturer
                                            </span>
                                            break;
                                        default:
                                            <span style="background:rgba(0,0,0,0.04); color:var(--text-muted); border:1px solid rgba(0,0,0,0.08); padding:6px 16px; border-radius:50px; font-size:13px; font-weight:700; display:inline-flex; align-items:center; gap:6px;">
                                                <i class="bi bi-question-circle"></i> Unknown
                                            </span>
                                            break;
                                    }
                                </div>
                            </div>
                        </div>
                        <div style="margin-top:24px;">
                            <button type="button" id="btnUpdateProfile" class="btn"
                                    style="background:linear-gradient(135deg,#0077b6,#0096c7); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:12px 28px; letter-spacing:1px; font-size:14px;">
                                <i class="bi bi-check-circle me-2"></i>Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Account Actions -->
            <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; overflow:hidden; margin-bottom:16px;">
                <div style="background:rgba(0,0,0,0.01); border-bottom:1px solid rgba(0,0,0,0.04); padding:14px 20px;">
                    <h6 style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:12px; margin:0; letter-spacing:1px;">
                        <i class="bi bi-gear me-2" style="color:var(--text-muted);"></i>Account Actions
                    </h6>
                </div>
                <div style="padding:16px; display:flex; flex-direction:column; gap:8px;">
                    <a href="/Index" class="btn"
                       style="background:rgba(0,119,182,0.06); border:1px solid rgba(0,119,182,0.15); color:#0077b6; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:600; padding:10px 16px; text-decoration:none; text-align:left;">
                        <i class="bi bi-house me-2"></i>Back to Dashboard
                    </a>
                    @if (Model.IsStaff)
                    {
                        <a href="/News/History" class="btn"
                           style="background:rgba(217,119,6,0.06); border:1px solid rgba(217,119,6,0.15); color:#d97706; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:600; padding:10px 16px; text-decoration:none; text-align:left;">
                            <i class="bi bi-clock-history me-2"></i>My News History
                        </a>
                    }
                    <button type="button" id="btnLogout" class="btn"
                            style="background:rgba(220,38,38,0.06); border:1px solid rgba(220,38,38,0.15); color:#dc2626; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:600; padding:10px 16px; text-align:left;">
                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                    </button>
                </div>
            </div>

            <!-- Quick Stats -->
            @if (Model.IsStaff)
            {
                <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; overflow:hidden;">
                    <div style="background:rgba(217,119,6,0.03); border-bottom:1px solid rgba(217,119,6,0.08); padding:14px 20px;">
                        <h6 style="font-family:'Orbitron',sans-serif; color:#d97706; font-size:12px; margin:0; letter-spacing:1px;">
                            <i class="bi bi-lightning-fill me-2"></i>Quick Stats
                        </h6>
                    </div>
                    <div style="padding:16px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid rgba(0,0,0,0.04);">
                            <span style="color:var(--text-muted); font-size:13px;">Articles Created</span>
                            <span style="font-family:'Orbitron',sans-serif; color:#d97706; font-size:18px; font-weight:700;">@Model.NewsCount</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid rgba(0,0,0,0.04);">
                            <span style="color:var(--text-muted); font-size:13px;">Account Role</span>
                            <span style="color:#0077b6; font-size:13px; font-weight:600;">Staff</span>
                        </div>
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0;">
                            <span style="color:var(--text-muted); font-size:13px;">Last Login</span>
                            <span style="color:var(--text-muted); font-size:13px;">@DateTime.Now.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#btnUpdateProfile').click(function() {
                $.post('?handler=Update', $('#profileForm').serialize(), function(response) {
                    if (response.success) { alert('Profile updated successfully!'); location.reload(); }
                    else { alert('Error: ' + response.message); }
                });
            });

            $('#btnLogout').click(function() {
                if (confirm('Are you sure you want to logout?')) {
                    window.location.href = '/Profile?handler=Logout';
                }
            });

            $('#newPassword, #confirmPassword').on('input', function() {
                const newPassword = $('#newPassword').val();
                const confirmPassword = $('#confirmPassword').val();
                if (newPassword !== confirmPassword && confirmPassword !== '') {
                    $('#confirmPassword')[0].setCustomValidity('Passwords do not match');
                } else {
                    $('#confirmPassword')[0].setCustomValidity('');
                }
            });
        });
    </script>
}

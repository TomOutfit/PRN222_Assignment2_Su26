<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FUNews</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NguyenBinhAnRazorPages.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@300;400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        *, body { margin: 0; padding: 0; box-sizing: border-box; }
        html { position: relative; min-height: 100%; }

        body {
            margin-bottom: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            font-family: 'Rajdhani', sans-serif;
            background: #050510;
            color: #e0e0ff;
        }

        /* ===== SCANLINES ===== */
        .scanlines {
            position: fixed;
            inset: 0;
            z-index: 999;
            pointer-events: none;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.015) 2px, rgba(0,0,0,0.015) 4px);
        }

        /* ===== HEADER ===== */
        .cyber-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(5, 5, 16, 0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(0, 255, 255, 0.1);
            box-shadow: 0 0 30px rgba(0, 255, 255, 0.04);
        }

        .cyber-navbar {
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 60px;
        }

        .cyber-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            font-family: 'Orbitron', sans-serif;
            font-weight: 800;
            font-size: 18px;
            color: #fff;
            letter-spacing: 2px;
            transition: all 0.3s;
        }

        .cyber-brand:hover { color: #fff; text-shadow: 0 0 20px rgba(0,255,255,0.5); }

        .brand-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #00ffff, #ff00ff);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px;
            color: #050510;
            box-shadow: 0 0 15px rgba(0,255,255,0.3);
            animation: brandPulse 3s ease-in-out infinite;
        }

        @@keyframes brandPulse {
            0%, 100% { box-shadow: 0 0 10px rgba(0,255,255,0.3); }
            50%       { box-shadow: 0 0 25px rgba(0,255,255,0.6), 0 0 40px rgba(255,0,255,0.2); }
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            border-radius: 6px;
            color: rgba(255, 255, 255, 0.65);
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s;
            border: 1px solid transparent;
            letter-spacing: 0.3px;
        }

        .nav-links a:hover {
            color: #fff;
            background: rgba(0, 255, 255, 0.07);
            border-color: rgba(0, 255, 255, 0.15);
            text-shadow: 0 0 8px rgba(0,255,255,0.4);
        }

        .nav-links .nav-active {
            color: #00ffff;
            border-color: rgba(0, 255, 255, 0.2);
            background: rgba(0, 255, 255, 0.05);
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 5px 14px 5px 5px;
            border-radius: 50px;
            background: rgba(255, 0, 255, 0.07);
            border: 1px solid rgba(255, 0, 255, 0.2);
            text-decoration: none;
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .user-chip:hover {
            background: rgba(255, 0, 255, 0.12);
            border-color: rgba(255, 0, 255, 0.4);
            color: #fff;
            box-shadow: 0 0 15px rgba(255,0,255,0.15);
        }

        .user-avatar {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: linear-gradient(135deg, #00ffff, #ff00ff);
            display: flex; align-items: center; justify-content: center;
            color: #050510;
            font-weight: 800;
            font-size: 12px;
        }

        .signin-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 18px;
            border-radius: 50px;
            background: rgba(0, 255, 255, 0.07);
            border: 1px solid rgba(0, 255, 255, 0.25);
            text-decoration: none;
            color: #00ffff;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.5px;
            transition: all 0.3s;
        }

        .signin-chip:hover {
            background: rgba(0, 255, 255, 0.12);
            color: #00ffff;
            box-shadow: 0 0 20px rgba(0,255,255,0.2);
        }

        /* ===== MAIN ===== */
        main {
            flex: 1;
        }

        /* ===== FOOTER ===== */
        .cyber-footer {
            position: relative;
            z-index: 1;
            border-top: 1px solid rgba(0, 255, 255, 0.06);
            padding: 28px 0 20px;
            text-align: center;
        }

        .footer-brand {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 14px;
            color: #fff;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .footer-brand-icon {
            width: 28px; height: 28px;
            background: linear-gradient(135deg, #00ffff, #ff00ff);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            color: #050510;
            font-size: 12px;
        }

        .footer-copy {
            color: rgba(255, 255, 255, 0.2);
            font-size: 12px;
            letter-spacing: 0.5px;
        }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 992px) {
            .nav-links { display: none; }
        }
    </style>
</head>
<body>
    <div class="scanlines"></div>

    <header class="cyber-header">
        <nav class="container cyber-navbar">
            <a class="cyber-brand" asp-area="" asp-page="/Index">
                <div class="brand-icon"><i class="bi bi-newspaper"></i></div>
                FUN<span style="color:#00ffff">NEWS</span>
            </a>

            @{
                var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
            }
            <ul class="nav-links">
                <li>
                    <a asp-area="" asp-page="/Index" class="@(currentPage == "/Index" ? "nav-active" : "")">
                        <i class="bi bi-house-door"></i> Home
                    </a>
                </li>
                <li>
                    <a asp-area="" asp-page="/News/View" class="@(currentPage == "/News/View" ? "nav-active" : "")">
                        <i class="bi bi-compass"></i> Browse
                    </a>
                </li>
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    var userRole = Context.Session.GetInt32("AccountRole");
                    @if (userRole == 1)
                    {
                        <li>
                            <a asp-area="" asp-page="/News/Index" class="@(currentPage.StartsWith("/News") && currentPage != "/News/View" && currentPage != "/News/History" ? "nav-active" : "")">
                                <i class="bi bi-pen"></i> Write
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-page="/Categories/Index" class="@(currentPage.StartsWith("/Categories") ? "nav-active" : "")">
                                <i class="bi bi-folder"></i> Categories
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-page="/News/History" class="@(currentPage == "/News/History" ? "nav-active" : "")">
                                <i class="bi bi-clock-history"></i> History
                            </a>
                        </li>
                    }
                    @if (userRole == 0)
                    {
                        <li>
                            <a asp-area="" asp-page="/Accounts/Index" class="@(currentPage.StartsWith("/Accounts") ? "nav-active" : "")">
                                <i class="bi bi-people"></i> Accounts
                            </a>
                        </li>
                        <li>
                            <a asp-area="" asp-page="/Statistics" class="@(currentPage == "/Statistics" ? "nav-active" : "")">
                                <i class="bi bi-bar-chart"></i> Reports
                            </a>
                        </li>
                    }
                }
            </ul>

            <div>
                @if (Context.Session.GetString("UserEmail") != null)
                {
                    <a class="user-chip" asp-area="" asp-page="/Profile">
                        <div class="user-avatar">
                            @Context.Session.GetString("UserName")?.Substring(0, 1).ToUpper()
                        </div>
                        <span>@Context.Session.GetString("UserName")</span>
                    </a>
                }
                else
                {
                    <a class="signin-chip" asp-area="" asp-page="/Login">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </a>
                }
            </div>
        </nav>
    </header>

    <main role="main">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container" style="padding-top:16px;">
                <div class="alert alert-dismissible fade show" role="alert" style="background:rgba(0,255,136,0.08); border:1px solid rgba(0,255,136,0.2); border-radius:10px; color:#00ff88; padding:12px 16px; font-family:'Rajdhani',sans-serif; font-size:14px;">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" style="opacity:0.5;"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container" style="padding-top:16px;">
                <div class="alert alert-dismissible fade show" role="alert" style="background:rgba(255,0,50,0.08); border:1px solid rgba(255,0,50,0.2); border-radius:10px; color:#ff6666; padding:12px 16px; font-family:'Rajdhani',sans-serif; font-size:14px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" style="opacity:0.5;"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="cyber-footer">
        <div class="container">
            <a class="footer-brand" asp-area="" asp-page="/Index">
                <div class="footer-brand-icon"><i class="bi bi-newspaper"></i></div>
                FUN<span style="color:#00ffff">NEWS</span>
            </a>
            <p class="footer-copy mb-0">
                &copy; 2026 FUNews Management System &bull; PRN222 Assignment 02
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function logout() {
            if (confirm('Are you sure you want to logout?')) {
                window.location.href = '/Profile?handler=Logout';
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

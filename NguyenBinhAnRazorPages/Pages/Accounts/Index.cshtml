@page
@model NguyenBinhAnRazorPages.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "Account Management";
}
@attribute [AdminOnly]

<style>
    body { font-family: 'Rajdhani', sans-serif; background: var(--bg-main); color: var(--text-main); }
</style>

@Html.AntiForgeryToken()
<div class="container-fluid py-4" style="position:relative; z-index:1;">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-family:'Orbitron',sans-serif; font-size:1.6rem; color:var(--text-main); margin-bottom:4px;">
                <i class="bi bi-people-fill me-2" style="color:#4f46e5;"></i> Account Management
            </h2>
            <p style="color:var(--text-muted); font-size:14px; margin:0;">Manage system accounts and user roles</p>
        </div>
        <button type="button" class="btn" data-bs-toggle="modal" data-bs-target="#createAccountModal"
                style="background:linear-gradient(135deg,#4f46e5,#3730a3); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 24px; letter-spacing:1px; font-size:14px; font-weight:700;">
            <i class="bi bi-person-plus me-2"></i>Create Account
        </button>
    </div>

    <!-- Search -->
    <div class="row mb-4">
        <div class="col-md-5">
            <form method="get" class="d-flex">
                <div style="position:relative; flex:1;">
                    <input type="text" name="searchTerm" class="form-control"
                           style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); padding:10px 16px 10px 40px; border-radius:8px 0 0 8px; font-family:'Rajdhani',sans-serif;"
                           placeholder="Search accounts..." value="@Model.SearchTerm" />
                    <i class="bi bi-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted);"></i>
                </div>
                <button type="submit" class="btn"
                        style="background:rgba(79,70,229,0.06); border:1px solid rgba(79,70,229,0.25); color:#4f46e5; border-radius:0 8px 8px 0; font-family:'Rajdhani',sans-serif;">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    @if (Model.TotalRecords > 0)
    {
        <div style="background:rgba(79,70,229,0.04); border:1px solid rgba(79,70,229,0.15); border-radius:10px; padding:10px 16px; margin-bottom:16px; display:inline-flex; align-items:center; gap:8px;">
            <i class="bi bi-info-circle" style="color:#4f46e5;"></i>
            <span style="color:var(--text-muted); font-size:13px;">Showing <strong style="color:var(--text-main);">@Model.StartRecord–@Model.EndRecord</strong> of <strong style="color:var(--text-main);">@Model.TotalRecords</strong> accounts</span>
        </div>
    }

    <!-- Table -->
    @if (!Model.Accounts.Any())
    {
        <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; padding:60px; text-align:center;">
            <i class="bi bi-inbox" style="font-size:48px; color:var(--text-muted); display:block; margin-bottom:16px;"></i>
            <h4 style="color:var(--text-main); font-family:'Orbitron',sans-serif;">No Accounts Found</h4>
            <p style="color:var(--text-muted); font-size:14px;">No accounts match your search.</p>
        </div>
    }
    else
    {
        <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; overflow:hidden;">
            <div class="table-responsive">
                <table class="table mb-0" style="color:var(--text-main); font-family:'Rajdhani',sans-serif; --bs-table-bg: transparent;">
                    <thead>
                        <tr style="background:rgba(79,70,229,0.03); border-bottom:1px solid rgba(79,70,229,0.1);">
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#4f46e5;">#</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#4f46e5;">ID</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#4f46e5;">Name</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#4f46e5;">Email</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#4f46e5;">Role</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#4f46e5;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = Model.StartRecord;
                        }
                        @foreach (var account in Model.Accounts)
                        {
                            var roleColor = account.AccountRole == 0 ? ("#dc2626", "rgba(220,38,38,0.07)", "rgba(220,38,38,0.2)")
                                : account.AccountRole == 1 ? ("#0077b6", "rgba(0,119,182,0.07)", "rgba(0,119,182,0.2)")
                                : ("#d97706", "rgba(217,119,6,0.07)", "rgba(217,119,6,0.2)");
                            var roleName = account.AccountRole == 0 ? "Admin" : account.AccountRole == 1 ? "Staff" : "Lecturer";
                            <tr style="border-bottom:1px solid rgba(0,0,0,0.04); transition:background 0.2s;" onmouseover="this.style.background='rgba(0,0,0,0.02)'" onmouseout="this.style.background='transparent'">
                                <td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">@rowIndex</td>
                                @{ rowIndex++; }
                                <td style="padding:14px 16px; color:#4f46e5; font-size:13px; font-family:'Orbitron',sans-serif;">#@account.AccountId</td>
                                <td style="padding:14px 16px; font-size:14px; font-weight:600; color:var(--text-main);">@account.AccountName</td>
                                <td style="padding:14px 16px; font-size:13px; color:var(--text-muted);">@account.AccountEmail</td>
                                <td style="padding:14px 16px;">
                                    <span style="background:@roleColor.Item2; color:@roleColor.Item1; border:1px solid @roleColor.Item3; padding:3px 12px; border-radius:50px; font-size:12px; font-weight:700; letter-spacing:0.5px;">
                                        @if (account.AccountRole == 0) { <i class="bi bi-shield-check me-1"></i> }
                                        else if (account.AccountRole == 1) { <i class="bi bi-person-badge me-1"></i> }
                                        else { <i class="bi bi-mortarboard me-1"></i> }
                                        @roleName
                                    </span>
                                </td>
                                <td style="padding:14px 16px;">
                                    <button type="button" class="btn btn-sm btn-edit"
                                            style="background:rgba(79,70,229,0.06); border:1px solid rgba(79,70,229,0.2); color:#4f46e5; border-radius:6px; font-size:12px; padding:5px 12px; margin-right:4px;"
                                            data-id="@account.AccountId" data-name="@account.AccountName"
                                            data-email="@account.AccountEmail" data-role="@account.AccountRole">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    @if (account.AccountRole != 0)
                                    {
                                        <button type="button" class="btn btn-sm btn-delete"
                                                style="background:rgba(220,38,38,0.06); border:1px solid rgba(220,38,38,0.2); color:#dc2626; border-radius:6px; font-size:12px; padding:5px 12px;"
                                                data-id="@account.AccountId" data-name="@account.AccountName">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @{
                int currentGroupStart = ((Model.CurrentPage - 1) / Model.PageSize) * Model.PageSize + 1;
                int currentGroupEnd = Math.Min(currentGroupStart + Model.PageSize - 1, Model.TotalPages);
            }
            @if (Model.TotalPages > 1)
            {
                <div style="padding:16px; border-top:1px solid rgba(0,0,0,0.05);">
                    <nav>
                        <ul class="pagination justify-content-center mb-0" style="gap:4px;">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/Accounts/Index?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage - 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Previous</a>
                            </li>
                            @if (currentGroupStart > 1)
                            {
                                <li class="page-item"><a class="page-link" href="/Accounts/Index?searchTerm=@Model.SearchTerm&pageIndex=@(currentGroupStart - 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">...</a></li>
                            }
                            @for (int i = currentGroupStart; i <= currentGroupEnd; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" href="/Accounts/Index?searchTerm=@Model.SearchTerm&pageIndex=@i"
                                       style="background:@(Model.CurrentPage == i ? "linear-gradient(135deg,#4f46e5,#3730a3)" : "rgba(0,0,0,0.02)"); border:1px solid @(Model.CurrentPage == i ? "transparent" : "rgba(0,0,0,0.06)"); color:@(Model.CurrentPage == i ? "#fff" : "var(--text-muted)"); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:@(Model.CurrentPage == i ? "700" : "400");">@i</a>
                                </li>
                            }
                            @if (currentGroupEnd < Model.TotalPages)
                            {
                                <li class="page-item"><a class="page-link" href="/Accounts/Index?searchTerm=@Model.SearchTerm&pageIndex=@(currentGroupEnd + 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">...</a></li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="/Accounts/Index?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage + 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<!-- Create Modal -->
<div class="modal fade" id="createAccountModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px;">
            <div class="modal-header" style="border-bottom:1px solid rgba(0,0,0,0.06); padding:20px 24px;">
                <h5 style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:15px; margin:0;">
                    <i class="bi bi-person-plus me-2" style="color:#4f46e5;"></i>Create Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <form id="createForm">
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Name</label>
                        <input type="text" class="form-control" id="createName" name="AccountName" required
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Email</label>
                        <input type="email" class="form-control" id="createEmail" name="AccountEmail" required
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Password</label>
                        <input type="password" class="form-control" id="createPassword" name="AccountPassword" required
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Role</label>
                        <select class="form-control" id="createRole" name="AccountRole" required
                                style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;">
                            <option value="" style="color:var(--text-main); background:var(--bg-card);">Select Role</option>
                            <option value="1" style="color:#0077b6; background:var(--bg-card);">Staff</option>
                            <option value="2" style="color:#d97706; background:var(--bg-card);">Lecturer</option>
                        </select>
                        <small style="color:var(--text-muted); opacity:0.6; font-size:12px; margin-top:4px; display:block;">Admin accounts cannot be created here.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top:1px solid rgba(0,0,0,0.06); padding:16px 24px; gap:8px;">
                <button type="button" class="btn" data-bs-dismiss="modal"
                        style="background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.08); color:var(--text-muted); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px;">Cancel</button>
                <button type="button" class="btn" id="btnCreate"
                        style="background:linear-gradient(135deg,#4f46e5,#3730a3); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 24px; letter-spacing:1px;">
                    <i class="bi bi-check-circle me-1"></i>Create
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editAccountModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px;">
            <div class="modal-header" style="border-bottom:1px solid rgba(0,0,0,0.06); padding:20px 24px;">
                <h5 style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:15px; margin:0;">
                    <i class="bi bi-pencil me-2" style="color:#4f46e5;"></i>Edit Account
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <form id="editForm">
                    <input type="hidden" id="editId" name="AccountId" />
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Name</label>
                        <input type="text" class="form-control" id="editName" name="AccountName" required
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Email</label>
                        <input type="email" class="form-control" id="editEmail" name="AccountEmail" required
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">New Password</label>
                        <input type="password" class="form-control" id="editPassword" name="AccountPassword"
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;" />
                        <small style="color:var(--text-muted); opacity:0.6; font-size:12px; margin-top:4px; display:block;">Leave blank to keep current password.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Role</label>
                        <select class="form-control" id="editRole" name="AccountRole" required
                                style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;">
                            <option value="" style="color:var(--text-main); background:var(--bg-card);">Select Role</option>
                            <option value="1" style="color:#0077b6; background:var(--bg-card);">Staff</option>
                            <option value="2" style="color:#d97706; background:var(--bg-card);">Lecturer</option>
                        </select>
                        <small style="color:var(--text-muted); opacity:0.6; font-size:12px; margin-top:4px; display:block;">Admin role cannot be changed here.</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="border-top:1px solid rgba(0,0,0,0.06); padding:16px 24px; gap:8px;">
                <button type="button" class="btn" data-bs-dismiss="modal"
                        style="background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.08); color:var(--text-muted); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px;">Cancel</button>
                <button type="button" class="btn" id="btnUpdate"
                        style="background:linear-gradient(135deg,#4f46e5,#3730a3); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 24px; letter-spacing:1px;">
                    <i class="bi bi-check-circle me-1"></i>Update
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background:var(--bg-card); border:1px solid rgba(220,38,38,0.25); border-radius:16px;">
            <div class="modal-header" style="border-bottom:1px solid rgba(220,38,38,0.1); padding:20px 24px;">
                <h5 style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:15px; margin:0;">
                    <i class="bi bi-exclamation-triangle me-2" style="color:#dc2626;"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center" style="padding:32px 24px;">
                <i class="bi bi-person-x" style="font-size:48px; color:rgba(220,38,38,0.3); display:block; margin-bottom:16px;"></i>
                <p style="color:var(--text-main); font-size:15px; margin-bottom:4px;">Delete account:</p>
                <p style="color:#dc2626; font-weight:700; font-size:16px;" id="deleteTitle"></p>
                <p style="color:var(--text-muted); font-size:13px; margin-top:12px;">This action cannot be undone.</p>
            </div>
            <div class="modal-footer" style="border-top:1px solid rgba(220,38,38,0.1); padding:16px 24px; gap:8px;">
                <button type="button" class="btn" data-bs-dismiss="modal"
                        style="background:rgba(0,0,0,0.04); border:1px solid rgba(0,0,0,0.08); color:var(--text-muted); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px;">Cancel</button>
                <button type="button" class="btn" id="btnConfirmDelete"
                        style="background:linear-gradient(135deg,#dc2626,#b91c1c); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 24px; letter-spacing:1px;">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#btnCreate').click(function() {
                const token = $('input[name="__RequestVerificationToken"]').first().val();
                const formData = $('#createForm').serialize() + '&__RequestVerificationToken=' + encodeURIComponent(token);
                $.post('?handler=Create', formData, function(response) {
                    if (response.success) { $('#createAccountModal').modal('hide'); location.reload(); }
                    else { alert('Error: ' + response.message); }
                });
            });

            $('.btn-edit').click(function() {
                $('#editId').val($(this).data('id'));
                $('#editName').val($(this).data('name'));
                $('#editEmail').val($(this).data('email'));
                $('#editRole').val($(this).data('role'));
                $('#editPassword').val('');
                $('#editAccountModal').modal('show');
            });

            $('#btnUpdate').click(function() {
                const token = $('input[name="__RequestVerificationToken"]').first().val();
                const formData = $('#editForm').serialize() + '&__RequestVerificationToken=' + encodeURIComponent(token);
                $.post('?handler=Update', formData, function(response) {
                    if (response.success) { $('#editAccountModal').modal('hide'); location.reload(); }
                    else { alert('Error: ' + response.message); }
                });
            });

            $('.btn-delete').click(function() {
                $('#deleteTitle').text($(this).data('name'));
                $('#deleteModal').modal('show');
                $('#btnConfirmDelete').data('id', $(this).data('id'));
            });

            $('#btnConfirmDelete').click(function() {
                const token = $('input[name="__RequestVerificationToken"]').first().val();
                $.post('?handler=Delete', { id: $(this).data('id'), __RequestVerificationToken: token }, function(response) {
                    if (response.success) { $('#deleteModal').modal('hide'); location.reload(); }
                    else { alert('Error: ' + response.message); }
                });
            });
        });
    </script>
}

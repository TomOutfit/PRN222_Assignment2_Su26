@page
@model NguyenBinhAnRazorPages.Pages.News.HistoryModel
@{
    ViewData["Title"] = "My News History";
}
@attribute [StaffOnly]

<style>
    body { font-family: 'Rajdhani', sans-serif; background: var(--bg-main); color: var(--text-main); }
</style>

<div class="container-fluid py-4" style="position:relative; z-index:1;">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-family:'Orbitron',sans-serif; font-size:1.6rem; color:var(--text-main); margin-bottom:4px;">
                <i class="bi bi-clock-history me-2" style="color:#d64f00;"></i> My News History
            </h2>
            <p style="color:var(--text-muted); font-size:14px; margin:0;">Your created articles at a glance</p>
        </div>
        <a href="/News" class="btn" style="background:rgba(214,79,0,0.06); border:1px solid rgba(214,79,0,0.25); color:#d64f00; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px; font-weight:600; text-decoration:none;">
            <i class="bi bi-plus-circle me-2"></i>Create New
        </a>
    </div>

    <!-- Search -->
    <div class="row mb-4">
        <div class="col-md-5">
            <form method="get" class="d-flex">
                <div style="position:relative; flex:1;">
                    <input type="text" name="searchTerm" class="form-control"
                           style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); padding:10px 16px 10px 40px; border-radius:8px 0 0 8px; font-family:'Rajdhani',sans-serif;"
                           placeholder="Search your articles..." value="@Model.SearchTerm" />
                    <i class="bi bi-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted);"></i>
                </div>
                <button type="submit" class="btn"
                        style="background:rgba(214,79,0,0.06); border:1px solid rgba(214,79,0,0.25); color:#d64f00; border-radius:0 8px 8px 0; font-family:'Rajdhani',sans-serif;">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    @if (Model.TotalRecords > 0)
    {
        <div style="background:rgba(214,79,0,0.04); border:1px solid rgba(214,79,0,0.15); border-radius:10px; padding:10px 16px; margin-bottom:16px; display:inline-flex; align-items:center; gap:8px;">
            <i class="bi bi-info-circle" style="color:#d64f00;"></i>
            <span style="color:var(--text-muted); font-size:13px;">Showing <strong style="color:var(--text-main);">@Model.StartRecord–@Model.EndRecord</strong> of <strong style="color:var(--text-main);">@Model.TotalRecords</strong> articles</span>
        </div>
    }

    <!-- Table -->
    @if (!Model.NewsArticles.Any())
    {
        <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; padding:60px; text-align:center;">
            <i class="bi bi-inbox" style="font-size:48px; color:var(--text-muted); display:block; margin-bottom:16px;"></i>
            <h4 style="color:var(--text-main); font-family:'Orbitron',sans-serif;">No Articles Found</h4>
            <p style="color:var(--text-muted); font-size:14px;">You haven't created any articles yet.</p>
            <a href="/News" class="btn" style="background:rgba(214,79,0,0.06); border:1px solid rgba(214,79,0,0.25); color:#d64f00; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 24px; margin-top:16px; text-decoration:none; display:inline-block;">
                <i class="bi bi-plus-circle me-2"></i>Create Your First Article
            </a>
        </div>
    }
    else
    {
        <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; overflow:hidden;">
            <div class="table-responsive">
                <table class="table mb-0" style="color:var(--text-main); font-family:'Rajdhani',sans-serif; --bs-table-bg: transparent;">
                    <thead>
                        <tr style="background:rgba(214,79,0,0.03); border-bottom:1px solid rgba(214,79,0,0.1);">
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">#</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">ID</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Title</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Headline</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Category</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Status</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Created</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Modified</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#d64f00;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = Model.StartRecord;
                        }
                        @foreach (var news in Model.NewsArticles)
                        {
                            <tr style="border-bottom:1px solid rgba(0,0,0,0.04); transition:background 0.2s;" onmouseover="this.style.background='rgba(0,0,0,0.02)'" onmouseout="this.style.background='transparent'">
                                <td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">@rowIndex</td>
                                @{ rowIndex++; }
                                <td style="padding:14px 16px; color:#d64f00; font-size:13px; font-family:'Orbitron',sans-serif;">#@news.NewsArticleId</td>
                                <td style="padding:14px 16px; font-size:14px; font-weight:600; color:var(--text-main); max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.NewsTitle</td>
                                <td style="padding:14px 16px; font-size:13px; color:var(--text-muted); max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.Headline</td>
                                <td style="padding:14px 16px;">
                                    <span style="background:rgba(214,79,0,0.08); color:#d64f00; border:1px solid rgba(214,79,0,0.2); padding:3px 10px; border-radius:50px; font-size:12px;">@news.Category?.CategoryName</span>
                                </td>
                                <td style="padding:14px 16px;">
                                    @if (news.NewsStatus == true)
                                    {
                                        <span style="background:rgba(0,180,80,0.08); color:#009944; border:1px solid rgba(0,180,80,0.15); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span style="background:rgba(0,0,0,0.04); color:var(--text-muted); border:1px solid rgba(0,0,0,0.08); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">@news.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">@(news.ModifiedDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td style="padding:14px 16px;">
                                    <a href="/News/Detail/@news.NewsArticleId" class="btn btn-sm"
                                       style="background:rgba(0,180,216,0.06); border:1px solid rgba(0,180,216,0.2); color:#0077b6; border-radius:6px; font-size:12px; padding:5px 12px; margin-right:4px; text-decoration:none;">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a href="/News?editId=@news.NewsArticleId" class="btn btn-sm"
                                       style="background:rgba(214,79,0,0.06); border:1px solid rgba(214,79,0,0.2); color:#d64f00; border-radius:6px; font-size:12px; padding:5px 12px; text-decoration:none;">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @{
                int currentGroupStart = ((Model.CurrentPage - 1) / Model.PageSize) * Model.PageSize + 1;
                int currentGroupEnd = Math.Min(currentGroupStart + Model.PageSize - 1, Model.TotalPages);
            }
            @if (Model.TotalPages > 1)
            {
                <div style="padding:16px; border-top:1px solid rgba(0,0,0,0.05);">
                    <nav>
                        <ul class="pagination justify-content-center mb-0" style="gap:4px;">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage - 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Previous</a>
                            </li>
                            @if (currentGroupStart > 1)
                            {
                                <li class="page-item"><a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(currentGroupStart - 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">...</a></li>
                            }
                            @for (int i = currentGroupStart; i <= currentGroupEnd; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@i"
                                       style="background:@(Model.CurrentPage == i ? "linear-gradient(135deg,#d64f00,#ff7700)" : "rgba(0,0,0,0.02)"); border:1px solid @(Model.CurrentPage == i ? "transparent" : "rgba(0,0,0,0.06)"); color:@(Model.CurrentPage == i ? "#fff" : "var(--text-muted)"); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:@(Model.CurrentPage == i ? "700" : "400");">@i</a>
                                </li>
                            }
                            @if (currentGroupEnd < Model.TotalPages)
                            {
                                <li class="page-item"><a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(currentGroupEnd + 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">...</a></li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage + 1)"
                                   style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

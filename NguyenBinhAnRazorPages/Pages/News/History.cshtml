@page
@model NguyenBinhAnRazorPages.Pages.News.HistoryModel
@{
    ViewData["Title"] = "My News History";
}
@attribute [StaffOnly]

<style>
    body { font-family: 'Rajdhani', sans-serif; background: #050510; color: #e0e0ff; }
</style>

<div class="container-fluid py-4" style="position:relative; z-index:1;">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-family:'Orbitron',sans-serif; font-size:1.6rem; color:#fff; margin-bottom:4px;">
                <i class="bi bi-clock-history me-2" style="color:#ffc800;"></i> My News History
            </h2>
            <p style="color:rgba(255,255,255,0.4); font-size:14px; margin:0;">Your created articles at a glance</p>
        </div>
        <a href="/News" class="btn" style="background:rgba(255,200,0,0.1); border:1px solid rgba(255,200,0,0.3); color:#ffc800; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px; font-weight:600; text-decoration:none;">
            <i class="bi bi-plus-circle me-2"></i>Create New
        </a>
    </div>

    <!-- Search -->
    <div class="row mb-4">
        <div class="col-md-5">
            <form method="get" class="d-flex">
                <div style="position:relative; flex:1;">
                    <input type="text" name="searchTerm" class="form-control"
                           style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; padding:10px 16px 10px 40px; border-radius:8px 0 0 8px; font-family:'Rajdhani',sans-serif;"
                           placeholder="Search your articles..." value="@Model.SearchTerm" />
                    <i class="bi bi-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:rgba(255,255,255,0.3);"></i>
                </div>
                <button type="submit" class="btn"
                        style="background:rgba(255,200,0,0.1); border:1px solid rgba(255,200,0,0.3); color:#ffc800; border-radius:0 8px 8px 0; font-family:'Rajdhani',sans-serif;">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    @if (Model.TotalRecords > 0)
    {
        <div style="background:rgba(255,200,0,0.05); border:1px solid rgba(255,200,0,0.1); border-radius:10px; padding:10px 16px; margin-bottom:16px; display:inline-flex; align-items:center; gap:8px;">
            <i class="bi bi-info-circle" style="color:#ffc800;"></i>
            <span style="color:rgba(255,255,255,0.5); font-size:13px;">Showing <strong style="color:#fff;">@Model.StartRecord–@Model.EndRecord</strong> of <strong style="color:#fff;">@Model.TotalRecords</strong> articles</span>
        </div>
    }

    <!-- Table -->
    @if (!Model.NewsArticles.Any())
    {
        <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:16px; padding:60px; text-align:center;">
            <i class="bi bi-inbox" style="font-size:48px; color:rgba(255,255,255,0.15); display:block; margin-bottom:16px;"></i>
            <h4 style="color:rgba(255,255,255,0.5); font-family:'Orbitron',sans-serif;">No Articles Found</h4>
            <p style="color:rgba(255,255,255,0.3); font-size:14px;">You haven't created any articles yet.</p>
            <a href="/News" class="btn" style="background:rgba(255,200,0,0.1); border:1px solid rgba(255,200,0,0.3); color:#ffc800; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 24px; margin-top:16px; text-decoration:none; display:inline-block;">
                <i class="bi bi-plus-circle me-2"></i>Create Your First Article
            </a>
        </div>
    }
    else
    {
        <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.06); border-radius:16px; overflow:hidden;">
            <div class="table-responsive">
                <table class="table mb-0" style="color:#e0e0ff; font-family:'Rajdhani',sans-serif; --bs-table-bg: transparent;">
                    <thead>
                        <tr style="background:rgba(255,200,0,0.04); border-bottom:1px solid rgba(255,200,0,0.1);">
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">#</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">ID</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Title</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Headline</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Category</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Status</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Created</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Modified</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(255,200,0,0.6);">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = Model.StartRecord;
                        }
                        @foreach (var news in Model.NewsArticles)
                        {
                            <tr style="border-bottom:1px solid rgba(255,255,255,0.04); transition:background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.03)'" onmouseout="this.style.background='transparent'">
                                <td style="padding:14px 16px; color:rgba(255,255,255,0.3); font-size:13px;">@rowIndex</td>
                                @{ rowIndex++; }
                                <td style="padding:14px 16px; color:rgba(255,200,0,0.5); font-size:13px; font-family:'Orbitron',sans-serif;">#@news.NewsArticleId</td>
                                <td style="padding:14px 16px; font-size:14px; font-weight:600; color:#fff; max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.NewsTitle</td>
                                <td style="padding:14px 16px; font-size:13px; color:rgba(255,255,255,0.5); max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.Headline</td>
                                <td style="padding:14px 16px;">
                                    <span style="background:rgba(255,102,0,0.1); color:#ff6600; border:1px solid rgba(255,102,0,0.2); padding:3px 10px; border-radius:50px; font-size:12px;">@news.Category?.CategoryName</span>
                                </td>
                                <td style="padding:14px 16px;">
                                    @if (news.NewsStatus == true)
                                    {
                                        <span style="background:rgba(0,255,136,0.1); color:#00ff88; border:1px solid rgba(0,255,136,0.2); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                    }
                                    else
                                    {
                                        <span style="background:rgba(128,128,128,0.1); color:#888; border:1px solid rgba(128,128,128,0.2); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                    }
                                </td>
                                <td style="padding:14px 16px; color:rgba(255,255,255,0.4); font-size:13px;">@news.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="padding:14px 16px; color:rgba(255,255,255,0.4); font-size:13px;">@(news.ModifiedDate?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                                <td style="padding:14px 16px;">
                                    <a href="/News/Detail/@news.NewsArticleId" class="btn btn-sm"
                                       style="background:rgba(0,255,255,0.08); border:1px solid rgba(0,255,255,0.2); color:#00ffff; border-radius:6px; font-size:12px; padding:5px 12px; margin-right:4px; text-decoration:none;">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    <a href="/News/Edit/@news.NewsArticleId" class="btn btn-sm"
                                       style="background:rgba(255,200,0,0.08); border:1px solid rgba(255,200,0,0.2); color:#ffc800; border-radius:6px; font-size:12px; padding:5px 12px; text-decoration:none;">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @{
                int currentGroupStart = ((Model.CurrentPage - 1) / Model.PageSize) * Model.PageSize + 1;
                int currentGroupEnd = Math.Min(currentGroupStart + Model.PageSize - 1, Model.TotalPages);
            }
            @if (Model.TotalPages > 1)
            {
                <div style="padding:16px; border-top:1px solid rgba(255,255,255,0.05);">
                    <nav>
                        <ul class="pagination justify-content-center mb-0" style="gap:4px;">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage - 1)"
                                   style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.5); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Previous</a>
                            </li>
                            @if (currentGroupStart > 1)
                            {
                                <li class="page-item"><a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(currentGroupStart - 1)"
                                   style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.5); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">...</a></li>
                            }
                            @for (int i = currentGroupStart; i <= currentGroupEnd; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@i"
                                       style="background:@(Model.CurrentPage == i ? "linear-gradient(135deg,#ffc800,#ffaa00)" : "rgba(255,255,255,0.04)"); border:1px solid @(Model.CurrentPage == i ? "transparent" : "rgba(255,255,255,0.08)"); color:@(Model.CurrentPage == i ? "#050510" : "rgba(255,255,255,0.5)"); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:@(Model.CurrentPage == i ? "700" : "400");">@i</a>
                                </li>
                            }
                            @if (currentGroupEnd < Model.TotalPages)
                            {
                                <li class="page-item"><a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(currentGroupEnd + 1)"
                                   style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.5); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">...</a></li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="/News/History?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage + 1)"
                                   style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.5); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

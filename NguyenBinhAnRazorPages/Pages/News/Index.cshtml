@page
@model NguyenBinhAnRazorPages.Pages.News.IndexModel
@{
    ViewData["Title"] = "News Management";
}
@attribute [StaffOnly]

<style>
    body { font-family: 'Rajdhani', sans-serif; background: var(--bg-main); color: var(--text-main); }
</style>

<form id="antiforgery-form" method="post">
    @Html.AntiForgeryToken()
</form>

<div class="container-fluid py-4" style="position:relative; z-index:1;">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-family:'Orbitron',sans-serif; font-size:1.6rem; color:var(--text-main); margin-bottom:4px;">
                <i class="bi bi-file-earmark-post-fill me-2" style="color:#0077b6;"></i> News Management
            </h2>
            <p style="color:var(--text-muted); font-size:14px; margin:0;">Create, edit, and manage news articles</p>
        </div>
        <button type="button" class="btn" data-bs-toggle="modal" data-bs-target="#createNewsModal"
                style="background:linear-gradient(135deg,#00b4d8,#0077b6); border:none; color:#fff; font-weight:700; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 24px; letter-spacing:1px; font-size:14px;">
            <i class="bi bi-plus-circle me-2"></i>Create News
        </button>
    </div>

    <!-- Search -->
    <div class="row mb-4">
        <div class="col-md-5">
            <form method="get" class="d-flex">
                <div style="position:relative; flex:1;">
                    <input type="text" name="searchTerm" class="form-control"
                           style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.08); color:var(--text-main); padding:10px 16px 10px 40px; border-radius:8px 0 0 8px; font-family:'Rajdhani',sans-serif;"
                           placeholder="Search news..." value="@Model.SearchTerm" />
                    <i class="bi bi-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-muted);"></i>
                </div>
                <button type="submit" class="btn btn-primary"
                        style="background:rgba(0,180,216,0.06); border:1px solid rgba(0,180,216,0.25); color:#0077b6; border-radius:0 8px 8px 0; font-family:'Rajdhani',sans-serif;">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>

    <!-- Info Bar -->
    <div id="info-bar" style="background:rgba(0,180,216,0.04); border:1px solid rgba(0,180,216,0.15); border-radius:10px; padding:10px 16px; margin-bottom:16px; display:@(Model.TotalRecords > 0 ? "inline-flex" : "none"); align-items:center; gap:8px;">
        <i class="bi bi-info-circle" style="color:#0077b6;"></i>
        <span style="color:var(--text-muted); font-size:13px;">Showing <strong id="start-record" style="color:var(--text-main);">@Model.StartRecord</strong>–<strong id="end-record" style="color:var(--text-main);">@Model.EndRecord</strong> of <strong id="total-records" style="color:var(--text-main);">@Model.TotalRecords</strong> articles</span>
    </div>

    <!-- Empty State -->
    <div id="empty-state" style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; padding:60px; text-align:center; display:@(Model.TotalRecords == 0 ? "block" : "none");">
        <i class="bi bi-inbox" style="font-size:48px; color:var(--text-muted); display:block; margin-bottom:16px;"></i>
        <h4 style="color:var(--text-main); font-family:'Orbitron',sans-serif;">No Articles Found</h4>
        <p style="color:var(--text-muted); font-size:14px;">Try adjusting your search term or create a new article.</p>
    </div>

    <!-- Table Container -->
    <div id="table-container" style="display:@(Model.TotalRecords > 0 ? "block" : "none");">
        <div style="background:var(--bg-card); border:1px solid var(--card-border); border-radius:16px; overflow:hidden;">
            <div class="table-responsive">
                <table class="table mb-0" style="color:var(--text-main); font-family:'Rajdhani',sans-serif; --bs-table-bg: transparent;">
                    <thead>
                        <tr style="background:rgba(0,180,216,0.03); border-bottom:1px solid rgba(0,180,216,0.1);">
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">#</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">ID</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">Title</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">Headline</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">Category</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">Status</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">Created</th>
                            <th style="padding:14px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#0077b6;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowIndex = Model.StartRecord;
                        }
                        @foreach (var news in Model.NewsArticles)
                        {
                            <tr id="row-@news.NewsArticleId" style="border-bottom:1px solid rgba(0,0,0,0.04); transition:background 0.2s;" onmouseover="this.style.background='rgba(0,0,0,0.02)'" onmouseout="this.style.background='transparent'">
                                <td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">@rowIndex</td>
                                @{ rowIndex++; }
                                <td style="padding:14px 16px; color:#0077b6; font-size:13px; font-family:'Orbitron',sans-serif;">#@news.NewsArticleId</td>
                                <td style="padding:14px 16px; font-size:14px; font-weight:600; color:var(--text-main); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.NewsTitle</td>
                                <td style="padding:14px 16px; font-size:13px; color:var(--text-muted); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.Headline</td>
                                <td style="padding:14px 16px;">
                                    <span style="background:rgba(214,79,0,0.08); color:#d64f00; border:1px solid rgba(214,79,0,0.2); padding:3px 10px; border-radius:50px; font-size:12px;">@news.Category?.CategoryName</span>
                                </td>
                                <td style="padding:14px 16px;">
                                    @if (news.NewsStatus == true)
                                    {
                                        <span style="background:rgba(0,180,80,0.08); color:#009944; border:1px solid rgba(0,180,80,0.15); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;">
                                            <i class="bi bi-check-circle-fill me-1"></i>Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="background:rgba(0,0,0,0.04); color:var(--text-muted); border:1px solid rgba(0,0,0,0.08); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;">
                                            <i class="bi bi-x-circle me-1"></i>Inactive
                                        </span>
                                    }
                                </td>
                                <td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">@news.CreatedDate?.ToString("dd/MM/yyyy")</td>
                                <td style="padding:14px 16px;">
                                    <button type="button" class="btn btn-sm btn-edit"
                                            style="background:rgba(0,180,216,0.06); border:1px solid rgba(0,180,216,0.2); color:#0077b6; border-radius:6px; font-size:12px; padding:5px 12px; margin-right:4px;"
                                            data-id="@news.NewsArticleId">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>
                                    <button type="button" class="btn btn-sm btn-delete"
                                            style="background:rgba(220,38,38,0.06); border:1px solid rgba(220,38,38,0.2); color:#dc2626; border-radius:6px; font-size:12px; padding:5px 12px;"
                                            data-id="@news.NewsArticleId" data-title="@news.NewsTitle">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div id="pagination-container" style="padding:16px; border-top:1px solid rgba(0,0,0,0.05); display: @(Model.TotalPages > 1 ? "block" : "none");">
                <nav>
                    <ul class="pagination justify-content-center mb-0" id="pagination-list" style="gap:4px;">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")" id="prev-page-item">
                            <a class="page-link" id="prev-page-link" href="/News/Index?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage - 1)"
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Previous</a>
                        </li>
                        <span id="page-links-container" class="d-flex" style="gap:4px;">
                            @{
                                int pageGroup = Model.PageSize;
                                int currentGroupStart = ((Model.CurrentPage - 1) / pageGroup) * pageGroup + 1;
                                int currentGroupEnd = Math.Min(currentGroupStart + pageGroup - 1, Model.TotalPages);
                            }
                            @for (int i = currentGroupStart; i <= currentGroupEnd; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")" data-page="@i">
                                    <a class="page-link" href="/News/Index?searchTerm=@Model.SearchTerm&pageIndex=@i"
                                       style="background:@(Model.CurrentPage == i ? "linear-gradient(135deg,#00b4d8,#0077b6)" : "rgba(0,0,0,0.02)"); border:1px solid @(Model.CurrentPage == i ? "transparent" : "rgba(0,0,0,0.06)"); color:@(Model.CurrentPage == i ? "#fff" : "var(--text-muted)"); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:@(Model.CurrentPage == i ? "700" : "400");">@i</a>
                                </li>
                            }
                        </span>
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")" id="next-page-item">
                            <a class="page-link" id="next-page-link" href="/News/Index?searchTerm=@Model.SearchTerm&pageIndex=@(Model.CurrentPage + 1)"
                               style="background:rgba(0,0,0,0.02); border:1px solid rgba(0,0,0,0.06); color:var(--text-muted); border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px;">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createNewsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:16px; margin:0;">
                    <i class="bi bi-plus-circle me-2" style="color:#0077b6;"></i>Create News Article
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <form id="createForm">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Title</label>
                            <input type="text" class="form-control" id="createTitle" name="NewsTitle" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Headline</label>
                            <input type="text" class="form-control" id="createHeadline" name="Headline" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Content</label>
                            <textarea class="form-control" id="createContent" name="NewsContent" rows="4"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Source</label>
                            <input type="text" class="form-control" id="createSource" name="NewsSource" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Category</label>
                            <select class="form-control" id="createCategory" name="CategoryId" required>
                                <option value="">Select Category</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.CategoryId">@category.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Status</label>
                            <select class="form-control" id="createStatus" name="NewsStatus">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px;">Tags</label>
                            <div class="row">
                                @foreach (var tag in Model.Tags)
                                {
                                    <div class="col-md-4">
                                        <div class="form-check" style="margin-bottom:8px;">
                                            <input class="form-check-input" type="checkbox" name="TagIds" value="@tag.TagId" id="tag_@tag.TagId"
                                                   style="accent-color:#0077b6;" />
                                            <label class="form-check-label" for="tag_@tag.TagId" style="color:var(--text-muted); font-size:13px;">@tag.TagName</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="padding:16px 24px; gap:8px;">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"
                        style="border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px;">
                    Cancel
                </button>
                <button type="button" class="btn" id="btnCreate"
                        style="background:linear-gradient(135deg,#00b4d8,#0077b6); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 24px; letter-spacing:1px;">
                    <i class="bi bi-check-circle me-1"></i>Create
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editNewsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:16px; margin:0;">
                    <i class="bi bi-pencil me-2" style="color:#b300b3;"></i>Edit News Article
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:24px;">
                <form id="editForm">
                    <input type="hidden" id="editId" name="NewsArticleId" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Title</label>
                            <input type="text" class="form-control" id="editTitle" name="NewsTitle" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Headline</label>
                            <input type="text" class="form-control" id="editHeadline" name="Headline" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Content</label>
                            <textarea class="form-control" id="editContent" name="NewsContent" rows="4"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Source</label>
                            <input type="text" class="form-control" id="editSource" name="NewsSource" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Category</label>
                            <select class="form-control" id="editCategory" name="CategoryId" required>
                                <option value="">Select Category</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.CategoryId">@category.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Status</label>
                            <select class="form-control" id="editStatus" name="NewsStatus">
                                <option value="true">Active</option>
                                <option value="false">Inactive</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" style="color:var(--text-muted); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase; margin-bottom:8px;">Tags</label>
                            <div class="row">
                                @foreach (var tag in Model.Tags)
                                {
                                    <div class="col-md-4">
                                        <div class="form-check" style="margin-bottom:8px;">
                                            <input class="form-check-input" type="checkbox" name="TagIds" value="@tag.TagId" id="edit_tag_@tag.TagId"
                                                   style="accent-color:#b300b3;" />
                                            <label class="form-check-label" for="edit_tag_@tag.TagId" style="color:var(--text-muted); font-size:13px;">@tag.TagName</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" style="padding:16px 24px; gap:8px;">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"
                        style="border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px;">
                    Cancel
                </button>
                <button type="button" class="btn" id="btnUpdate"
                        style="background:linear-gradient(135deg,#ff00ff,#b300b3); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 24px; letter-spacing:1px;">
                    <i class="bi bi-check-circle me-1"></i>Update
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="font-family:'Orbitron',sans-serif; color:var(--text-main); font-size:16px; margin:0;">
                    <i class="bi bi-exclamation-triangle me-2" style="color:#d6002a;"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center" style="padding:32px 24px;">
                <i class="bi bi-trash" style="font-size:48px; color:rgba(214,0,42,0.4); display:block; margin-bottom:16px;"></i>
                <p style="color:var(--text-main); font-size:15px; margin-bottom:4px;">Delete article:</p>
                <p style="color:#d6002a; font-weight:700; font-size:16px;" id="deleteTitle"></p>
                <p style="color:var(--text-muted); font-size:13px; margin-top:12px;">This action cannot be undone.</p>
            </div>
            <div class="modal-footer" style="padding:16px 24px; gap:8px;">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal"
                        style="border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 20px;">
                    Cancel
                </button>
                <button type="button" class="btn" id="btnConfirmDelete"
                        style="background:linear-gradient(135deg,#ff0032,#d6002a); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 24px; letter-spacing:1px;">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        let connection;
        let totalRecords = @Model.TotalRecords;
        let currentPage = @Model.CurrentPage;
        let pageSize = @Model.PageSize;
        let startRecord = @Model.StartRecord;
        let endRecord = @Model.EndRecord;
        let searchTerm = '@Html.Raw(Model.SearchTerm)';

        function buildNewsRow(news) {
            const statusBadge = news.newsStatus
                ? '<span style="background:rgba(0,180,80,0.08); color:#009944; border:1px solid rgba(0,180,80,0.15); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Active</span>'
                : '<span style="background:rgba(0,0,0,0.04); color:var(--text-muted); border:1px solid rgba(0,0,0,0.08); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-x-circle me-1"></i>Inactive</span>';
            const createdDate = news.createdDate ? new Date(news.createdDate).toLocaleDateString('vi-VN') : '';
            return '<tr id="row-' + news.newsArticleId + '" style="border-bottom:1px solid rgba(0,0,0,0.04); transition:background 0.2s;" onmouseover="this.style.background=\'rgba(0,0,0,0.02)\'" onmouseout="this.style.background=\'transparent\'">' +
                '<td style="padding:14px 16px; color:var(--text-muted); font-size:13px;"></td>' +
                '<td style="padding:14px 16px; color:#0077b6; font-size:13px; font-family:\'Orbitron\',sans-serif;">#' + news.newsArticleId + '</td>' +
                '<td style="padding:14px 16px; font-size:14px; font-weight:600; color:var(--text-main); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">' + (news.newsTitle || '') + '</td>' +
                '<td style="padding:14px 16px; font-size:13px; color:var(--text-muted); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">' + (news.headline || '') + '</td>' +
                '<td style="padding:14px 16px;"><span style="background:rgba(214,79,0,0.08); color:#d64f00; border:1px solid rgba(214,79,0,0.2); padding:3px 10px; border-radius:50px; font-size:12px;">' + (news.category?.categoryName || '') + '</span></td>' +
                '<td style="padding:14px 16px;">' + statusBadge + '</td>' +
                '<td style="padding:14px 16px; color:var(--text-muted); font-size:13px;">' + createdDate + '</td>' +
                '<td style="padding:14px 16px;">' +
                '<button type="button" class="btn btn-sm btn-edit" style="background:rgba(0,180,216,0.06); border:1px solid rgba(0,180,216,0.2); color:#0077b6; border-radius:6px; font-size:12px; padding:5px 12px; margin-right:4px;" data-id="' + news.newsArticleId + '"><i class="bi bi-pencil"></i> Edit</button>' +
                '<button type="button" class="btn btn-sm btn-delete" style="background:rgba(220,38,38,0.06); border:1px solid rgba(220,38,38,0.2); color:#dc2626; border-radius:6px; font-size:12px; padding:5px 12px;" data-id="' + news.newsArticleId + '" data-title="' + (news.newsTitle || '') + '"><i class="bi bi-trash"></i> Delete</button>' +
                '</td></tr>';
        }

        function updateRowIndices() {
            $('table tbody tr').each(function (index) {
                $(this).find('td').first().text(startRecord + index);
            });
        }

        function updatePaginationUI() {
            let totalPages = Math.ceil(totalRecords / pageSize);
            if (totalPages > 1) {
                $('#pagination-container').show();
            } else {
                $('#pagination-container').hide();
            }

            let pageGroup = pageSize;
            let currentGroupStart = Math.floor((currentPage - 1) / pageGroup) * pageGroup + 1;
            let currentGroupEnd = Math.min(currentGroupStart + pageGroup - 1, totalPages);

            let linksHtml = '';
            for (let i = currentGroupStart; i <= currentGroupEnd; i++) {
                let activeClass = currentPage === i ? 'active' : '';
                let bgStyle = currentPage === i ? 'linear-gradient(135deg,#00b4d8,#0077b6)' : 'rgba(0,0,0,0.02)';
                let borderStyle = currentPage === i ? 'transparent' : 'rgba(0,0,0,0.06)';
                let colorStyle = currentPage === i ? '#fff' : 'var(--text-muted)';
                let fontWeight = currentPage === i ? '700' : '400';
                
                linksHtml += `<li class="page-item ${activeClass}" data-page="${i}">` +
                    `<a class="page-link" href="/News/Index?searchTerm=${encodeURIComponent(searchTerm)}&pageIndex=${i}" ` +
                    `style="background:${bgStyle}; border:1px solid ${borderStyle}; color:${colorStyle}; border-radius:6px; font-family:'Rajdhani',sans-serif; font-size:13px; font-weight:${fontWeight};">${i}</a>` +
                    `</li>`;
            }
            $('#page-links-container').html(linksHtml);

            // Update Previous/Next buttons
            if (currentPage === 1) {
                $('#prev-page-item').addClass('disabled');
                $('#prev-page-link').attr('href', '#');
            } else {
                $('#prev-page-item').removeClass('disabled');
                $('#prev-page-link').attr('href', `/News/Index?searchTerm=${encodeURIComponent(searchTerm)}&pageIndex=${currentPage - 1}`);
            }

            if (currentPage === totalPages || totalPages === 0) {
                $('#next-page-item').addClass('disabled');
                $('#next-page-link').attr('href', '#');
            } else {
                $('#next-page-item').removeClass('disabled');
                $('#next-page-link').attr('href', `/News/Index?searchTerm=${encodeURIComponent(searchTerm)}&pageIndex=${currentPage + 1}`);
            }
        }

        function updateUIState() {
            if (totalRecords === 0) {
                $('#empty-state').show();
                $('#table-container').hide();
                $('#info-bar').hide();
            } else {
                $('#empty-state').hide();
                $('#table-container').show();
                $('#info-bar').css('display', 'inline-flex');

                if (currentPage === 1) {
                    startRecord = 1;
                    endRecord = Math.min(totalRecords, pageSize);
                } else {
                    startRecord = (currentPage - 1) * pageSize + 1;
                    endRecord = Math.min(currentPage * pageSize, totalRecords);
                    if (startRecord > totalRecords) {
                        startRecord = Math.max(1, totalRecords);
                        endRecord = totalRecords;
                    }
                }

                $('#total-records').text(totalRecords);
                $('#start-record').text(startRecord);
                $('#end-record').text(endRecord);

                updateRowIndices();
                updatePaginationUI();
            }
        }

        function attachRowHandlers() {
            $(document).off('click', '.btn-edit').on('click', '.btn-edit', function () {
                const newsId = $(this).data('id');
                $.get('?handler=Edit&id=' + newsId, function (data) {
                    if (data.success) {
                        $('#editId').val(data.news.newsArticleId);
                        $('#editTitle').val(data.news.newsTitle);
                        $('#editHeadline').val(data.news.headline);
                        $('#editContent').val(data.news.newsContent);
                        $('#editSource').val(data.news.newsSource);
                        $('#editCategory').val(data.news.categoryId);
                        $('#editStatus').val(String(data.news.newsStatus));
                        $('#editTags input[type="checkbox"]').prop('checked', false);
                        data.news.tags.forEach(tagId => { $('#edit_tag_' + tagId).prop('checked', true); });
                        $('#editNewsModal').modal('show');
                    } else { alert('Error: ' + data.message); }
                });
            });

            $(document).off('click', '.btn-delete').on('click', '.btn-delete', function () {
                $('#deleteTitle').text($(this).data('title'));
                $('#deleteModal').modal('show');
                $('#btnConfirmDelete').data('id', $(this).data('id'));
            });
        }

        $(document).ready(function () {
            connection = new signalR.HubConnectionBuilder()
                .withUrl('/newsHub').withAutomaticReconnect().build();

            connection.on('NewsCreated', function (news) {
                $('table tbody').prepend(buildNewsRow(news));
                attachRowHandlers();

                totalRecords++;

                if ($('table tbody tr').length > pageSize) {
                    $('table tbody tr').last().remove();
                }

                updateUIState();
            });

            connection.on('NewsUpdated', function (news) {
                $('#row-' + news.newsArticleId).replaceWith(buildNewsRow(news));
                attachRowHandlers();
                updateUIState();
            });

            connection.on('NewsDeleted', function (newsArticleId) {
                const row = $('#row-' + newsArticleId);
                if (row.length) {
                    row.remove();
                    totalRecords--;
                    updateUIState();
                }
            });

            connection.start().catch(err => console.error('SignalR error:', err.toString()));
            attachRowHandlers();
            updateRowIndices();

            @if (!string.IsNullOrEmpty(Model.EditId))
            {
                <text>
                setTimeout(function() {
                    const btn = $('.btn-edit[data-id="@Model.EditId"]');
                    if (btn.length) {
                        btn.click();
                    } else {
                        const newsId = "@Model.EditId";
                        $.get('?handler=Edit&id=' + newsId, function (data) {
                            if (data.success) {
                                $('#editId').val(data.news.newsArticleId);
                                $('#editTitle').val(data.news.newsTitle);
                                $('#editHeadline').val(data.news.headline);
                                $('#editContent').val(data.news.newsContent);
                                $('#editSource').val(data.news.newsSource);
                                $('#editCategory').val(data.news.categoryId);
                                $('#editStatus').val(String(data.news.newsStatus));
                                $('#editTags input[type="checkbox"]').prop('checked', false);
                                data.news.tags.forEach(tagId => { $('#edit_tag_' + tagId).prop('checked', true); });
                                $('#editNewsModal').modal('show');
                            }
                        });
                    }
                }, 500);
                </text>
            }

            $('#btnCreate').click(function () {
                const token = $('input[name="__RequestVerificationToken"]').first().val();
                const formData = $('#createForm').serialize() + '&__RequestVerificationToken=' + encodeURIComponent(token);
                $.post('?handler=Create', formData, function (response) {
                    if (response.success) { $('#createNewsModal').modal('hide'); $('#createForm')[0].reset(); }
                    else { alert('Error: ' + response.message); }
                });
            });

            $('#btnUpdate').click(function () {
                const token = $('input[name="__RequestVerificationToken"]').first().val();
                const formData = $('#editForm').serialize() + '&__RequestVerificationToken=' + encodeURIComponent(token);
                $.post('?handler=Update', formData, function (response) {
                    if (response.success) { $('#editNewsModal').modal('hide'); }
                    else { alert('Error: ' + response.message); }
                });
            });

            $('#btnConfirmDelete').click(function () {
                const newsId = $(this).data('id');
                const token = $('input[name="__RequestVerificationToken"]').first().val();
                $.post('?handler=Delete', { id: newsId, __RequestVerificationToken: token }, function (response) {
                    if (response.success) { $('#deleteModal').modal('hide'); }
                    else { alert('Error: ' + response.message); }
                });
            });
        });
    </script>
}

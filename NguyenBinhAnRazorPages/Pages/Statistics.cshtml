@page
@model NguyenBinhAnRazorPages.Pages.StatisticsModel
@{
    ViewData["Title"] = "Statistics Report";
}
@attribute [AdminOnly]

<style>
    body { font-family: 'Rajdhani', sans-serif; background: #050510; color: #e0e0ff; }
</style>

<div class="container-fluid py-4" style="position:relative; z-index:1;">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h2 style="font-family:'Orbitron',sans-serif; font-size:1.6rem; color:#fff; margin-bottom:4px;">
                <i class="bi bi-bar-chart-fill me-2" style="color:#a78bfa;"></i> Statistics Report
            </h2>
            <p style="color:rgba(255,255,255,0.4); font-size:14px; margin:0;">System overview and analytics dashboard</p>
        </div>
    </div>

    <!-- Date Filter -->
    <div style="background:rgba(167,139,250,0.05); border:1px solid rgba(167,139,250,0.12); border-radius:16px; padding:20px 24px; margin-bottom:28px;">
        <form method="get" class="row g-3 align-items-end mb-0">
            <div class="col-md-4">
                <label style="color:rgba(255,255,255,0.5); font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; display:block; margin-bottom:6px;">Start Date</label>
                <input type="date" id="startDate" name="startDate" class="form-control"
                       style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;"
                       value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label style="color:rgba(255,255,255,0.5); font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; display:block; margin-bottom:6px;">End Date</label>
                <input type="date" id="endDate" name="endDate" class="form-control"
                       style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 14px;"
                       value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4" style="display:flex; gap:8px; align-items: flex-end;">
                <button type="submit" class="btn" style="background:linear-gradient(135deg,#a78bfa,#8b5cf6); border:none; color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; font-weight:700; padding:10px 20px; letter-spacing:1px; flex:1;">
                    <i class="bi bi-graph-up me-1"></i>Generate Report
                </button>
                <button type="button" id="btnClear" class="btn" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:rgba(255,255,255,0.5); border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 16px;">
                    <i class="bi bi-x-circle"></i>
                </button>
                
                <div class="dropdown">
                    <button class="btn dropdown-toggle" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#fff; border-radius:8px; font-family:'Rajdhani',sans-serif; padding:10px 16px; font-weight:700; display: flex; align-items: center; justify-content: center; gap: 4px;">
                        <i class="bi bi-download"></i> Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark" aria-labelledby="dropdownMenuButton" style="background:#0c0b1e; border:1px solid rgba(167,139,250,0.2); box-shadow: 0 4px 20px rgba(0,0,0,0.5); border-radius: 8px;">
                        <li><a class="dropdown-item py-2" href="#" onclick="exportPDF(); return false;"><i class="bi bi-file-earmark-pdf-fill me-2" style="color:#ef4444;"></i>Export PDF</a></li>
                        <li><a class="dropdown-item py-2" href="#" onclick="exportCSV(); return false;"><i class="bi bi-file-earmark-spreadsheet-fill me-2" style="color:#10b981;"></i>Export CSV</a></li>
                        <li><a class="dropdown-item py-2" href="#" onclick="exportJSON(); return false;"><i class="bi bi-filetype-json me-2" style="color:#3b82f6;"></i>Export JSON</a></li>
                    </ul>
                </div>
            </div>
        </form>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div style="background:rgba(0,255,255,0.05); border:1px solid rgba(0,255,255,0.12); border-top:3px solid #00ffff; border-radius:16px; padding:24px 20px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                    <div style="width:44px; height:44px; background:rgba(0,255,255,0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#00ffff; font-size:20px;">
                        <i class="bi bi-newspaper"></i>
                    </div>
                </div>
                <div style="font-family:'Orbitron',sans-serif; font-size:2.2rem; font-weight:800; color:#00ffff; line-height:1; margin-bottom:4px;">@Model.TotalNewsArticles</div>
                <div style="color:rgba(255,255,255,0.4); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Total Articles</div>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background:rgba(0,255,136,0.05); border:1px solid rgba(0,255,136,0.12); border-top:3px solid #00ff88; border-radius:16px; padding:24px 20px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                    <div style="width:44px; height:44px; background:rgba(0,255,136,0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#00ff88; font-size:20px;">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                </div>
                <div style="font-family:'Orbitron',sans-serif; font-size:2.2rem; font-weight:800; color:#00ff88; line-height:1; margin-bottom:4px;">@Model.ActiveNewsArticles</div>
                <div style="color:rgba(255,255,255,0.4); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Active Articles</div>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background:rgba(255,102,0,0.05); border:1px solid rgba(255,102,0,0.12); border-top:3px solid #ff6600; border-radius:16px; padding:24px 20px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                    <div style="width:44px; height:44px; background:rgba(255,102,0,0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#ff6600; font-size:20px;">
                        <i class="bi bi-folder-fill"></i>
                    </div>
                </div>
                <div style="font-family:'Orbitron',sans-serif; font-size:2.2rem; font-weight:800; color:#ff6600; line-height:1; margin-bottom:4px;">@Model.TotalCategories</div>
                <div style="color:rgba(255,255,255,0.4); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Categories</div>
            </div>
        </div>
        <div class="col-md-3">
            <div style="background:rgba(255,0,255,0.05); border:1px solid rgba(255,0,255,0.12); border-top:3px solid #ff00ff; border-radius:16px; padding:24px 20px;">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                    <div style="width:44px; height:44px; background:rgba(255,0,255,0.1); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#ff00ff; font-size:20px;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                </div>
                <div style="font-family:'Orbitron',sans-serif; font-size:2.2rem; font-weight:800; color:#ff00ff; line-height:1; margin-bottom:4px;">@Model.TotalAccounts</div>
                <div style="color:rgba(255,255,255,0.4); font-size:12px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">Accounts</div>
            </div>
        </div>
    </div>

    <!-- News Table -->
    <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(167,139,250,0.12); border-radius:16px; overflow:hidden; margin-bottom:28px;">
        <div style="background:rgba(167,139,250,0.05); border-bottom:1px solid rgba(167,139,250,0.1); padding:16px 24px;">
            <h5 style="font-family:'Orbitron',sans-serif; color:#fff; font-size:14px; margin:0; letter-spacing:1px;">
                <i class="bi bi-list-ul me-2" style="color:#a78bfa;"></i>News Articles (Sorted by Created Date)
            </h5>
        </div>
        <div class="table-responsive">
            <table class="table mb-0" style="color:#e0e0ff; font-family:'Rajdhani',sans-serif; --bs-table-bg: transparent;">
                <thead>
                    <tr style="background:rgba(167,139,250,0.03); border-bottom:1px solid rgba(167,139,250,0.08);">
                        <th style="padding:12px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(167,139,250,0.6);">ID</th>
                        <th style="padding:12px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(167,139,250,0.6);">Title</th>
                        <th style="padding:12px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(167,139,250,0.6);">Category</th>
                        <th style="padding:12px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(167,139,250,0.6);">Creator</th>
                        <th style="padding:12px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(167,139,250,0.6);">Created</th>
                        <th style="padding:12px 16px; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(167,139,250,0.6);">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var news in Model.NewsStatistics)
                    {
                        <tr style="border-bottom:1px solid rgba(255,255,255,0.03);">
                            <td style="padding:12px 16px; color:rgba(167,139,250,0.5); font-size:13px; font-family:'Orbitron',sans-serif;">#@news.NewsArticleId</td>
                            <td style="padding:12px 16px; font-size:14px; font-weight:600; color:#fff; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">@news.NewsTitle</td>
                            <td style="padding:12px 16px;"><span style="background:rgba(255,102,0,0.1); color:#ff6600; border:1px solid rgba(255,102,0,0.2); padding:3px 10px; border-radius:50px; font-size:12px;">@news.Category?.CategoryName</span></td>
                            <td style="padding:12px 16px; color:rgba(255,255,255,0.5); font-size:13px;">@news.Creator?.AccountName</td>
                            <td style="padding:12px 16px; color:rgba(255,255,255,0.4); font-size:13px;">@news.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="padding:12px 16px;">
                                @if (news.NewsStatus == true)
                                {
                                    <span style="background:rgba(0,255,136,0.1); color:#00ff88; border:1px solid rgba(0,255,136,0.2); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Active</span>
                                }
                                else
                                {
                                    <span style="background:rgba(128,128,128,0.1); color:#888; border:1px solid rgba(128,128,128,0.2); padding:3px 10px; border-radius:50px; font-size:12px; font-weight:600;"><i class="bi bi-x-circle me-1"></i>Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.NewsStatistics.Any())
        {
            <div style="padding:40px; text-align:center;">
                <i class="bi bi-inbox" style="font-size:36px; color:rgba(255,255,255,0.15); display:block; margin-bottom:12px;"></i>
                <p style="color:rgba(255,255,255,0.4); font-size:14px;">No articles found in selected date range.</p>
            </div>
        }
    </div>

    <!-- Charts -->
    <div class="row g-3">
        <div class="col-md-6">
            <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(0,255,255,0.1); border-radius:16px; overflow:hidden;">
                <div style="background:rgba(0,255,255,0.04); border-bottom:1px solid rgba(0,255,255,0.08); padding:14px 20px;">
                    <h6 style="font-family:'Orbitron',sans-serif; color:#00ffff; font-size:12px; margin:0; letter-spacing:1px;">
                        <i class="bi bi-pie-chart-fill me-2"></i>News by Category
                    </h6>
                </div>
                <div style="padding:24px;">
                    <canvas id="categoryChart" style="max-height:280px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div style="background:rgba(255,255,255,0.02); border:1px solid rgba(255,0,255,0.1); border-radius:16px; overflow:hidden;">
                <div style="background:rgba(255,0,255,0.04); border-bottom:1px solid rgba(255,0,255,0.08); padding:14px 20px;">
                    <h6 style="font-family:'Orbitron',sans-serif; color:#ff00ff; font-size:12px; margin:0; letter-spacing:1px;">
                        <i class="bi bi-bar-chart-fill me-2"></i>News by Creator
                    </h6>
                </div>
                <div style="padding:24px;">
                    <canvas id="creatorChart" style="max-height:280px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function exportCSV() {
            const startDate = $('#startDate').val() || '';
            const endDate = $('#endDate').val() || '';
            window.location.href = `/Statistics?handler=ExportCsv&startDate=${startDate}&endDate=${endDate}`;
        }

        function exportJSON() {
            const startDate = $('#startDate').val() || '';
            const endDate = $('#endDate').val() || '';
            window.location.href = `/Statistics?handler=ExportJson&startDate=${startDate}&endDate=${endDate}`;
        }

        function exportPDF() {
            const startDate = $('#startDate').val() || 'All_Time';
            const endDate = $('#endDate').val() || 'Present';
            const reportPeriod = `Period: ${startDate} to ${endDate}`;
            const generatedAt = `Generated on: ${new Date().toLocaleString()}`;
            
            let tableRows = '';
            @foreach (var news in Model.NewsStatistics)
            {
                <text>
                tableRows += `
                    <tr>
                        <td style="padding: 10px; border: 1px solid #ddd; font-family: monospace;">#@news.NewsArticleId</td>
                        <td style="padding: 10px; border: 1px solid #ddd; font-weight: bold;">@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(news.NewsTitle ?? ""))</td>
                        <td style="padding: 10px; border: 1px solid #ddd;">@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(news.Category?.CategoryName ?? ""))</td>
                        <td style="padding: 10px; border: 1px solid #ddd;">@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(news.Creator?.AccountName ?? ""))</td>
                        <td style="padding: 10px; border: 1px solid #ddd;">@news.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="padding: 10px; border: 1px solid #ddd;">@(news.NewsStatus == true ? "Active" : "Inactive")</td>
                    </tr>
                `;
                </text>
            }

            if (tableRows === '') {
                tableRows = '<tr><td colspan="6" style="padding: 20px; text-align: center; color: #888;">No articles found in this period.</td></tr>';
            }

            const printHtml = `
                <div style="padding: 40px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333; background: #fff;">
                    <!-- Header -->
                    <div style="border-bottom: 2px solid #3b82f6; padding-bottom: 20px; margin-bottom: 30px;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td>
                                    <h1 style="margin: 0; color: #1e3a8a; font-size: 26px; font-weight: 800;">FUNewsTradingSystem</h1>
                                    <p style="margin: 5px 0 0 0; color: #6b7280; font-size: 14px; font-weight: 500;">STATISTICS REPORT</p>
                                </td>
                                <td style="text-align: right; vertical-align: bottom;">
                                    <p style="margin: 0; font-size: 12px; color: #4b5563; font-weight: bold;">${reportPeriod}</p>
                                    <p style="margin: 4px 0 0 0; font-size: 11px; color: #9ca3af;">${generatedAt}</p>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <!-- Summary Cards -->
                    <div style="display: flex; gap: 20px; margin-bottom: 30px;">
                        <div style="flex: 1; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; background: #f9fafb; text-align: center;">
                            <div style="font-size: 24px; font-weight: 800; color: #1e3a8a;">@Model.TotalNewsArticles</div>
                            <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; font-weight: bold; margin-top: 5px;">Total Articles</div>
                        </div>
                        <div style="flex: 1; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; background: #f9fafb; text-align: center;">
                            <div style="font-size: 24px; font-weight: 800; color: #10b981;">@Model.ActiveNewsArticles</div>
                            <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; font-weight: bold; margin-top: 5px;">Active Articles</div>
                        </div>
                        <div style="flex: 1; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; background: #f9fafb; text-align: center;">
                            <div style="font-size: 24px; font-weight: 800; color: #ff6600;">@Model.TotalCategories</div>
                            <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; font-weight: bold; margin-top: 5px;">Categories</div>
                        </div>
                        <div style="flex: 1; border: 1px solid #e5e7eb; border-radius: 8px; padding: 15px; background: #f9fafb; text-align: center;">
                            <div style="font-size: 24px; font-weight: 800; color: #8b5cf6;">@Model.TotalAccounts</div>
                            <div style="font-size: 11px; color: #6b7280; text-transform: uppercase; font-weight: bold; margin-top: 5px;">Accounts</div>
                        </div>
                    </div>

                    <!-- Table -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 40px; font-size: 12px;">
                        <thead>
                            <tr style="background: #f3f4f6; border-bottom: 2px solid #d1d5db;">
                                <th style="padding: 10px; border: 1px solid #ddd; text-align: left; font-weight: bold; color: #374151; width: 10%;">ID</th>
                                <th style="padding: 10px; border: 1px solid #ddd; text-align: left; font-weight: bold; color: #374151; width: 40%;">Title</th>
                                <th style="padding: 10px; border: 1px solid #ddd; text-align: left; font-weight: bold; color: #374151; width: 15%;">Category</th>
                                <th style="padding: 10px; border: 1px solid #ddd; text-align: left; font-weight: bold; color: #374151; width: 15%;">Creator</th>
                                <th style="padding: 10px; border: 1px solid #ddd; text-align: left; font-weight: bold; color: #374151; width: 12%;">Created</th>
                                <th style="padding: 10px; border: 1px solid #ddd; text-align: left; font-weight: bold; color: #374151; width: 8%;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${tableRows}
                        </tbody>
                    </table>

                    <!-- Signatures / Footer -->
                    <div style="margin-top: 60px; page-break-inside: avoid;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <tr>
                                <td style="width: 50%; text-align: center;">
                                    <p style="margin: 0; font-size: 12px; color: #4b5563; font-weight: bold;">Prepared By</p>
                                    <div style="height: 60px;"></div>
                                    <p style="margin: 0; font-size: 12px; font-weight: bold; color: #111827;">System Administrator</p>
                                </td>
                                <td style="width: 50%; text-align: center;">
                                    <p style="margin: 0; font-size: 12px; color: #4b5563; font-weight: bold;">Authorized Approval</p>
                                    <div style="height: 60px;"></div>
                                    <p style="margin: 0; font-size: 12px; font-weight: bold; color: #111827;">FUNews Board of Management</p>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            `;

            const opt = {
                margin:       15,
                filename:     `NewsReport_${startDate}_to_${endDate}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true, logging: false },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(printHtml).save();
        }

        $(document).ready(function() {
            $('#btnClear').click(function() {
                $('#startDate').val('');
                $('#endDate').val('');
                window.location.href = '/Statistics';
            });

            const cyberColors = ['#00ffff', '#ff00ff', '#00ff88', '#ff6600', '#ffc800', '#a78bfa', '#ff0032', '#22d3ee'];

            const categoryLabels = @Html.Raw(Model.CategoryLabels);
            const categoryData = @Html.Raw(Model.CategoryData);
            if (categoryLabels.length > 0) {
                new Chart(document.getElementById('categoryChart').getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: categoryLabels,
                        datasets: [{ data: categoryData, backgroundColor: cyberColors, borderColor: '#050510', borderWidth: 2 }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.5)', font: { family: 'Rajdhani', size: 12 } } }
                        }
                    }
                });
            } else {
                document.getElementById('categoryChart').parentElement.innerHTML = '<p style="color:rgba(255,255,255,0.3); text-align:center; font-size:14px; padding:40px 0;">No data available</p>';
            }

            const creatorLabels = @Html.Raw(Model.CreatorLabels);
            const creatorData = @Html.Raw(Model.CreatorData);
            if (creatorLabels.length > 0) {
                new Chart(document.getElementById('creatorChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: creatorLabels,
                        datasets: [{ label: 'Articles', data: creatorData, backgroundColor: cyberColors.slice(0, creatorLabels.length), borderRadius: 6 }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { beginAtZero: true, ticks: { color: 'rgba(255,255,255,0.4)', font: { family: 'Rajdhani' } }, grid: { color: 'rgba(255,255,255,0.05)' } },
                            x: { ticks: { color: 'rgba(255,255,255,0.4)', font: { family: 'Rajdhani' } }, grid: { display: false } }
                        }
                    }
                });
            } else {
                document.getElementById('creatorChart').parentElement.innerHTML = '<p style="color:rgba(255,255,255,0.3); text-align:center; font-size:14px; padding:40px 0;">No data available</p>';
            }
        });
    </script>
}
